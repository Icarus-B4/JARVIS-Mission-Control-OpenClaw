{
  "name": "elite-mission-control",
  "version": "2.0.8",
  "description": "Elite Mission Control — agent task management system with CLI",
  "bin": {
    "jarvis": "./scripts/jarvis.js"
  },
  "scripts": {
    "jarvis": "node ./scripts/jarvis.js",
    "server": "yarn --cwd server start",
    "server:all": "yarn --cwd server all",
    "dev": "yarn --cwd server dev",
    "install:all": "yarn install && yarn --cwd server install",
    "install-cli": "bash ./scripts/jarvis-install.sh",
    "test": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverage": false
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "csrf": "^3.1.0",
    "jest": "^30.2.0"
  }
}
