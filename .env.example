# Mission Control production environment example
# Copy to .env (project root) or .env.local and fill values.

# ------------------------------------------------------------
# Core server
# ------------------------------------------------------------
NODE_ENV=production
PORT=3000
# Directory that contains tasks/, agents/, messages/, queue/ etc.
# If empty, defaults to ./mission-control/.mission-control
MISSION_CONTROL_DIR=
# Optional if dashboard files are served from a custom path
DASHBOARD_DIR=
# Request body size cap for JSON payloads (default: 1mb)
JSON_BODY_LIMIT=1mb
# Optional CORS allowlist (comma-separated origins)
# Example: CORS_ORIGIN=https://mc.example.com,https://ops.example.com
CORS_ORIGIN=

# ------------------------------------------------------------
# Authentication / API access
# ------------------------------------------------------------
# Set both to enable dashboard basic auth
MC_AUTH_USER=
MC_AUTH_PASS=
# Optional token for trusted agent API access
MC_AGENT_TOKEN=

# ------------------------------------------------------------
# Integrations
# ------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
MISSIONDECK_API_KEY=
MISSIONDECK_SLUG=

# ------------------------------------------------------------
# OpenClaw / agent workspace integration
# ------------------------------------------------------------
# Path used by /api/agents/* SOUL file endpoints
AGENTS_DIR=
# Optional override for OpenClaw cron file autodetection
OPENCLAW_CRON_FILE=
# Optional gateway token (if OpenClaw bridge is enabled)
OPENCLAW_GATEWAY_TOKEN=
